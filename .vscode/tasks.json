{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NavHUD: Android map logs",
      "type": "shell",
      "command": "adb",
      "args": [
        "logcat",
        "-v",
        "time",
        "flutter:I",
        "*:S"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "NavHUD: Build ESP32",
      "type": "shell",
      "command": "ninja",
      "args": [
        "-C",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/esp32"
      },
      "problemMatcher": "$gcc"
    }
  ]
}
